# Optional overrides.
# If omitted, src/firebase.ts uses built-in defaults for openissue-40eaa project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
# Optional when storage is disabled
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# true: use Firebase Storage image attachments, false: disable storage usage
VITE_ENABLE_STORAGE=false
# Optional for GitHub Pages. Example: /openissue/
VITE_BASE_PATH=/
